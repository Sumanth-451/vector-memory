# Turso DB (required in production)
TURSO_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Agent identity (optional — defaults to 'fleet')
AGENT_ID=fleet

# Port (Railway sets this automatically)
PORT=3456

# Fleet bearer auth — set in Railway env vars; all endpoints except /health require
# Authorization: Bearer <FLEET_SECRET>. Leave unset for local dev (auth disabled).
FLEET_SECRET=your-fleet-secret
